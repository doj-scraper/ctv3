{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app/clerk/App.tsx",
    "app/clerk/Cart.tsx",
    "app/clerk/CartContext.tsx",
    "app/clerk/CartDrawer.tsx",
    "app/clerk/Header.tsx",
    "app/clerk/Home.tsx",
    "app/clerk/Orders.tsx",
    "app/clerk/ProductGrid.tsx",
    "app/clerk/cart.test.ts",
    "app/clerk/context.ts",
    "app/clerk/db.ts",
    "app/clerk/index.ts",
    "app/clerk/main.tsx",
    "app/clerk/oauth.ts",
    "app/clerk/relations.ts",
    "app/clerk/routers.ts",
    "app/clerk/schema.ts",
    "app/clerk/sdk.ts",
    "app/clerk/stripe-webhook.ts",
    "app/clerk/useAuth.ts"
  ]
}
